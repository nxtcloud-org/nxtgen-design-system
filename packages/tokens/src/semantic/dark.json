{
  "bg": {
    "canvas": {
      "$value": "{color.gray.950}",
      "$type": "color",
      "$description": "순수 #000 회피 — 시각 피로 감소"
    },
    "surface": { "$value": "{color.gray.900}", "$type": "color" },
    "subtle": { "$value": "{color.gray.800}", "$type": "color" },
    "muted": { "$value": "{color.gray.700}", "$type": "color" },
    "inverse": { "$value": "{color.gray.0}", "$type": "color" },
    "brand": { "$value": "{color.blue.500}", "$type": "color" },
    "brand-hover": { "$value": "{color.blue.400}", "$type": "color" },
    "brand-subtle": { "$value": "{color.blue.900}", "$type": "color" },
    "accent": { "$value": "{color.magenta.500}", "$type": "color" },
    "accent-hover": { "$value": "{color.magenta.400}", "$type": "color" },
    "success": { "$value": "{color.success.500}", "$type": "color" },
    "warning": { "$value": "{color.warning.500}", "$type": "color" },
    "danger": { "$value": "{color.danger.500}", "$type": "color" },
    "info": { "$value": "{color.info.400}", "$type": "color" }
  },
  "text": {
    "primary": { "$value": "{color.gray.50}", "$type": "color" },
    "secondary": { "$value": "{color.gray.300}", "$type": "color" },
    "tertiary": { "$value": "{color.gray.400}", "$type": "color" },
    "disabled": { "$value": "{color.gray.600}", "$type": "color" },
    "inverse": { "$value": "{color.gray.900}", "$type": "color" },
    "brand": { "$value": "{color.blue.400}", "$type": "color" },
    "accent": { "$value": "{color.magenta.400}", "$type": "color" },
    "success": { "$value": "{color.success.400}", "$type": "color" },
    "warning": { "$value": "{color.warning.400}", "$type": "color" },
    "danger": { "$value": "{color.danger.400}", "$type": "color" },
    "on-brand": { "$value": "{color.gray.0}", "$type": "color" }
  },
  "border": {
    "default": { "$value": "{color.gray.800}", "$type": "color", "$description": "dark surface 위의 차분한 outline. 이전 #FFFFFF12 alpha-white 는 검정 배경 위에서 발광 인상이 강해 눈 부담 (front-v2 user feedback 2026-05-11). gray.800 은 light 의 border.default(gray.200) 와 대칭 — bg.surface(gray.900) 한 단계 위 톤." },
    "subtle": { "$value": "{color.gray.900}", "$type": "color", "$description": "거의 invisible separator. bg.surface 와 동일 톤이라 강조 없는 구분선용. light 의 border.subtle(gray.100) 대칭." },
    "strong": { "$value": "{color.gray.700}", "$type": "color", "$description": "focus / hover 강조용. light 의 border.strong(gray.300) 대칭." },
    "focus": { "$value": "{color.blue.400}", "$type": "color" },
    "danger": { "$value": "{color.danger.400}", "$type": "color" }
  }
}
